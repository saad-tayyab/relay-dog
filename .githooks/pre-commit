#!/bin/bash
# pre-commit hook — runs Biome lint + format check, then type-check

set -e

echo "🔍 Running Biome checks..."

# Check if biome is available
if ! command -v bunx &> /dev/null; then
  echo "⚠️  bunx not found, skipping biome check"
  exit 0
fi

# Run Biome check (lint + format)
bunx biome check . 2>&1 || {
  echo ""
  echo "❌ Biome check failed. Run: bunx biome check --write ."
  exit 1
}

echo "✅ Biome checks passed"

echo "🔍 Running type checks..."

# Run type-check across all packages
bunx turbo type-check 2>&1 || {
  echo ""
  echo "❌ Type check failed. Fix errors before committing."
  echo "   Run: bunx turbo type-check"
  exit 1
}

echo "✅ All checks passed"
