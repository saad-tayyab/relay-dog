# Vercel only deploys the web app — exclude everything else

# Exclude API app (needs Bun runtime, not available on Vercel)
apps/api/

# Exclude non-essential files
docs/
infra/
drizzle/
.github/
*.md
docker-compose.yml
biome.json
CONTRIBUTING.md
AGENTS.md

# NOTE: Do NOT exclude packages/ subdirectories here — they are workspace
# members listed in root package.json and Bun needs them for workspace
# resolution. Also do NOT exclude bun.lock/bun.lockb — the install command
# uses --frozen-lockfile which requires the lockfile to exist.

# Keep these (web app workspace dependencies):
# packages/shared/       — types + schemas imported by web
# packages/ui/           — shared Svelte components (SectionCard, etc.)
# packages/config/env/   — environment parsing
# packages/config/tsconfig/ — shared TypeScript configs
