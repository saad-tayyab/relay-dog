{
  "name": "relayscope",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/config/*",
    "packages/shared"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint && bun run lint:root",
    "lint:fix": "biome check --write .",
    "format": "biome check --write .",
    "type-check": "turbo run type-check",
    "db:generate": "bun run --filter @relayscope/api db:generate",
    "db:migrate": "bun run --filter @relayscope/api db:migrate",
    "db:studio": "bun run --filter @relayscope/api db:studio",
    "lint:root": "biome check biome.json turbo.json docs .github CONTRIBUTING.md README.md package.json",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f db"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "turbo": "^2.10.2",
    "typescript": "^6.0"
  },
  "packageManager": "bun@1.3.14"
}
