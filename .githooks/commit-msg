#!/bin/bash
# commit-msg hook — enforce Conventional Commits format
# https://www.conventionalcommits.org/en/v1.0.0/
#
# Format: <type>(<scope>): <description>
#
# Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
# Scopes: web, api, shared, db, monitor, ui (optional)

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Conventional Commits regex
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_-]+\))?: .{1,}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Invalid commit message format."
  echo ""
  echo "  Expected: <type>(<scope>): <description>"
  echo ""
  echo "  Types:    feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert"
  echo "  Scopes:   web | api | shared | db | monitor | ui (optional)"
  echo ""
  echo "  Examples:"
  echo "    feat(web): add NIP-11 relay profile viewer"
  echo "    fix(api): handle CORS errors gracefully"
  echo "    docs: update README with API endpoints"
  echo "    chore: init turorepo monorepo"
  echo ""
  exit 1
fi

echo "✅ Commit message format valid"
