{
  "name": "relayscope",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome check --write .",
    "type-check": "turbo type-check",
    "db:generate": "cd apps/api && bun run db:generate",
    "db:migrate": "cd apps/api && bun run db:migrate",
    "db:studio": "cd apps/api && bun run db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "dotenv": "^17.4.2",
    "turbo": "^2",
    "typescript": "^6.0"
  },
  "packageManager": "bun@1.2.17"
}
