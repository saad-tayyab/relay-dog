{
  "name": "@relayscope/database",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./queries": {
      "types": "./src/queries.ts",
      "default": "./src/queries.ts"
    },
    "./relations": {
      "types": "./src/relations.ts",
      "default": "./src/relations.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "db:generate": "bun --bun run drizzle-kit generate",
    "db:migrate": "bun --bun run drizzle-kit migrate",
    "db:studio": "bun --bun run drizzle-kit studio",
    "db:push": "bun --bun run drizzle-kit push"
  },
  "dependencies": {
    "@relayscope/env": "workspace:*",
    "@relayscope/shared": "workspace:*",
    "drizzle-orm": "1.0.0-rc.4"
  },
  "devDependencies": {
    "@relayscope/tsconfig": "workspace:*",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "1.0.0-rc.4",
    "typescript": "^7.0.2"
  }
}
