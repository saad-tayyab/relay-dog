# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/relayscope
POSTGRES_PASSWORD=change-me-in-production

# ─── API ───
PORT=3001
NODE_ENV=development
API_KEY=dev-api-key-change-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── NIP-66 Monitor Relays (comma-separated, optional) ───
# MONITOR_RELAYS=wss://relay-monitor.migalmoreno.com

# ─── Frontend (client-side, optional) ───
# Vite prefix — bundled into the web app at build time
# Leave empty for frontend-only mode (no backend features)
# VITE_API_URL=https://your-api-server.com
